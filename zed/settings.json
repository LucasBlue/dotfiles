// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "terminal": {
    "shell": {
      "program": "/opt/homebrew/bin/fish" // 内置终端使用 fish shell
    }
  },
  "project_panel": {
    "dock": "left" // 项目文件树 停靠在左侧
  },
  "outline_panel": {
    "dock": "left" // 大纲面板(符号/函数列表)停靠在左侧
  },
  "collaboration_panel": {
    "dock": "left" // 协作面板 停靠在左侧
  },
  "git_panel": {
    "dock": "left", // Git 面板 停靠在左侧
    "tree_view": true // Git 改动以「树状目录」展示,而非平铺列表
  },
  "edit_predictions": {
    "mode": "eager" // AI 行内补全:eager = 主动积极地给出预测(相对 subtle)
  },
  "context_servers": {},
  // ───────────────────── Vim 相关设置 ─────────────────────
  "vim_mode": true, // 启用 Vim 模式(以上大量快捷键的前提)
  "vim": {
    "default_mode": "normal", // 打开文件时默认进入 普通模式
    "use_system_clipboard": "never", // 复制/删除默认只进 Vim 寄存器,不污染系统剪贴板(需要系统剪贴板要显式用 "+ 寄存器)
    "use_smartcase_find": true, // f / t / 搜索 智能大小写:全小写忽略大小写,含大写则精确匹配
    "toggle_relative_line_numbers": true, // 普通模式显示相对行号,插入模式自动切回绝对行号
    "highlight_on_yank_duration": 50, // 复制(yank)后高亮该段文本 50 毫秒,作为视觉反馈
    "custom_digraphs": {
      // 插入模式按下 Control + k 再输入对应缩写,可插入特殊符号
      "fz": "🧟‍♀️" // 例:Ctrl+k 然后输入 fz → 插入 🧟‍♀️
    }
  },
  "agent": {
    "dock": "right", // AI 助手面板 停靠在右侧
    "always_allow_tool_actions": true, // 允许 AI 直接执行工具操作,不每次弹窗确认
    "default_model": {
      "effort": "high", // 推理投入程度:高
      "enable_thinking": true, // 开启「思考」过程
      "provider": "zed.dev", // 模型提供方
      "model": "claude-opus-4-8" // 默认模型
    },
    "default_profile": "ask", // 默认使用 ask(问答)配置文件
    "model_parameters": []
  },
  "icon_theme": {
    "mode": "light", // 文件图标主题模式
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "telemetry": {
    "diagnostics": true, // 上报诊断信息
    "metrics": true // 上报使用指标
  },
  "base_keymap": "VSCode", // 基础键位方案 = VSCode(这也是 Ctrl+C/V/X 等能生效的底层原因)
  "minimap": {
    "show": "auto" // 右侧代码缩略图:自动(内容够长时才显示)
  },
  "autosave": "on_focus_change", // 自动保存:焦点离开当前文件时保存
  "buffer_font_fallbacks": [
    "Courier New",
    "monospace"
  ],
  "buffer_font_family": "JetBrains Mono", // 编辑区字体
  "file_types": {},
  "show_edit_predictions": true, // 显示 AI 行内补全建议
  "tab_size": 2, // 缩进 = 2 个空格
  "ui_font_size": 16, // 界面字号
  "buffer_font_size": 13.0, // 编辑区字号
  "theme": {
    "mode": "dark", // 使用暗色主题
    "light": "JetBrains Dark",
    "dark": "JetBrains Dark"
  },
  // 关闭光标闪烁
  "cursor_blink": false,
  // 使用相对行号
  "relative_line_numbers": "enabled",
  // 隐藏滚动条(当前未启用)
  // "scrollbar": { "show": "never" },
  // 禁止缓冲区滚动超过最后一行
  "scroll_beyond_last_line": "off",
  // 允许光标到达屏幕边缘(上下不预留边距)
  "vertical_scroll_margin": 0,
  "gutter": {
    // 显示行号(注:注释写的是「完全禁用」,但值是 true,即实际为显示)
    "line_numbers": true
  },
  "command_aliases": {
    // 命令行模式的大小写容错:即使 Shift 没松开也能正确执行
    "W": "w", // :W 等同 :w(保存)
    "Wq": "wq", // :Wq 等同 :wq(保存并关闭)
    "Q": "q" // :Q 等同 :q(关闭)
  },
  "formatter": "language_server", // 默认用语言服务器(LSP)格式化
  "format_on_save": "on", // 保存时自动格式化
  "code_actions_on_format": {
    "source.fixAll.eslint": true // 格式化时自动执行 ESLint 的可修复项
  },
  "languages": {
    // 以下四种语言单独再声明一遍「保存即格式化 + ESLint 自动修复」
    "JavaScript": {
      "formatter": "language_server",
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "TypeScript": {
      "formatter": "language_server",
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "TSX": {
      "formatter": "language_server",
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "JSX": {
      "formatter": "language_server",
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    }
  },
  "lsp": {
    "eslint": {
      "settings": {
        "codeActionOnSave": {
          "enable": true, // 保存时启用 ESLint 代码操作
          "mode": "all" // 应用全部可修复规则
        },
        "format": true, // 允许 ESLint 参与格式化
        "run": "onSave", // ESLint 校验时机:保存时
        "validate": "on" // 开启校验
      }
    }
  }
}
